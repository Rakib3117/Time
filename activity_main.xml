<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⏱️ TimeGate"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="অ্যাপ ব্যবহারের আগে সময় নির্ধারণ করুন"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠️ Accessibility Service বন্ধ"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="@color/card_bg"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/enableAccessibilityBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Accessibility চালু করুন"
        android:backgroundTint="@color/primary"
        android:layout_marginBottom="24dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="নজরদারি করা অ্যাপ"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

        <Button
            android:id="@+id/addAppBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ যোগ করুন"
            android:textSize="13sp"
            android:backgroundTint="@color/accent"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/appListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
